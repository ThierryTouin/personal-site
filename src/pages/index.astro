---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Blog" description="La partie blog">
  <ul class="posts">
    {posts.map((post) => (
      <li class="post">
        {post.data.featured && (
          <a href={`${base}blog/${post.id}/`} class="featured-link" aria-label={`Lire ${post.data.title}`}>
            <img class="featured-image" src={post.data.featured.src} alt={`Illustration de ${post.data.title}`} loading="lazy" />
          </a>
        )}
        <h2>
          <a href={`${base}blog/${post.id}/`}>{post.data.title}</a>
        </h2>
        <div class="meta">
          <span>Publié le {new Date(post.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
        </div>
        {post.data.description && (
          <p class="excerpt">{post.data.description}</p>
        )}
        <div class="button">
          <a href={`${base}blog/${post.id}/`}>Read More</a>
        </div>
      </li>
    ))}
  </ul>
</Layout>

<script>
  import mqtt from 'mqtt';

  // Initialize debug object
  window.__mqttDebug = {
    status: 'initializing',
    startTime: new Date().toISOString(),
    steps: [],
    error: null,
    ipData: null,
    connectionDetails: null,
    publishDetails: null,
  };

  function logDebug(step, details = {}) {
    const timestamp = new Date().toISOString();
    const entry = { timestamp, step, ...details };
    window.__mqttDebug.steps.push(entry);
    console.log(`[MQTT Analytics] ${step}:`, details);
  }

  async function publishVisitorIp() {
    try {
      // Step 1: Check if already sent
      if (window.__ttoMqttSent) {
        logDebug('SKIP', { reason: 'Analytics already sent in this session' });
        return;
      }

      logDebug('START', { message: 'Starting analytics publishing' });
      window.__ttoMqttSent = true;

      // Step 2: Fetch IP address
      logDebug('FETCH_IP_START', { url: 'https://api.ipify.org?format=json' });
      const response = await fetch('https://api.ipify.org?format=json', {
        signal: AbortSignal.timeout(5000), // 5 second timeout
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      }

      const data = await response.json();
      const ip = data?.ip;

      if (!ip) {
        throw new Error('IP address not found in response');
      }

      window.__mqttDebug.ipData = { ip, fetchedAt: new Date().toISOString() };
      logDebug('FETCH_IP_SUCCESS', { ip });

      // Step 3: Connect to MQTT broker
      const brokerUrl = 'wss://test.mosquitto.org:8081';
      logDebug('MQTT_CONNECT_START', {
        broker: brokerUrl,
        protocol: 'wss',
        port: 8081,
      });

      const client = mqtt.connect(brokerUrl, {
        reconnectPeriod: 1000,
        connectTimeout: 10000,
        clean: true,
      });

      // Step 4: Handle connection success
      client.on('connect', () => {
        window.__mqttDebug.connectionDetails = {
          connectedAt: new Date().toISOString(),
          clientId: client.options.clientId,
        };
        logDebug('MQTT_CONNECTED', { clientId: client.options.clientId });

        // Step 5: Publish payload
        const payload = {
          ts: new Date().getTime(),
          ip,
        };

        const topic = 'tto/page1';
        logDebug('MQTT_PUBLISH_START', {
          topic,
          payload,
        });

        client.publish(topic, JSON.stringify(payload), { retain: true }, (error) => {
          if (error) {
            window.__mqttDebug.error = error.message;
            window.__mqttDebug.status = 'error_publish';
            logDebug('MQTT_PUBLISH_ERROR', { error: error.message });
          } else {
            window.__mqttDebug.publishDetails = {
              topic,
              payload,
              publishedAt: new Date().toISOString(),
            };
            window.__mqttDebug.status = 'success';
            logDebug('MQTT_PUBLISH_SUCCESS', { topic });
          }

          // Step 6: Disconnect
          client.end(() => {
            logDebug('MQTT_DISCONNECTED', {
              totalSteps: window.__mqttDebug.steps.length,
            });
          });
        });
      });

      // Step 7: Handle connection errors
      client.on('error', (error) => {
        window.__mqttDebug.error = error.message;
        window.__mqttDebug.status = 'error_connection';
        logDebug('MQTT_CONNECTION_ERROR', {
          error: error.message,
          code: error.code,
        });
        client.end();
      });

      // Step 8: Handle offline event
      client.on('offline', () => {
        logDebug('MQTT_OFFLINE', { timestamp: new Date().toISOString() });
      });

      // Step 9: Handle close event
      client.on('close', () => {
        logDebug('MQTT_CLOSE', { timestamp: new Date().toISOString() });
      });
    } catch (error) {
      window.__mqttDebug.error = error.message;
      window.__mqttDebug.status = 'error_exception';
      logDebug('EXCEPTION', {
        error: error.message,
        stack: error.stack,
      });
    }

    logDebug('COMPLETE', {
      status: window.__mqttDebug.status,
      totalSteps: window.__mqttDebug.steps.length,
    });
  }

  // Expose helper function
  window.__getMqttDebug = () => window.__mqttDebug;

  publishVisitorIp();
</script>

<style lang="scss">
@use '../styles/global.scss' as *;

.posts {
  list-style-type: none;
  padding: 0;
  max-width: 750px;
  margin: 0 auto;
}

.post {
  padding-bottom: 40px;

  &:last-child {
    padding-bottom: 0;
  }

  h2 {
    font-size: 27px;
    margin: 0 0 10px;
    text-align: center;

    a {
      color: $color6;
      &:hover {
        color: #222;
      }
    }
  }
}

.featured-link {
  display: block;
  margin-bottom: 18px;
}

.featured-image {
  width: 100%;
  height: 260px;
  object-fit: cover;
  border-radius: 10px;
  border: 1px solid rgba(0, 0, 0, 0.08);
}

.meta {
  font-size: 13px;
  text-align: center;
  font-weight: 300;
  margin-bottom: 20px;
}

.excerpt {
  margin: 30px 0 15px;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.button {
  font-size: 14px;
  font-weight: 300;
  text-align: center;
  padding: 20px 0;

  a {
    color: #555;
    padding: 8px 12px;
    border: 1px solid #555;
    border-radius: 4px;

    &:hover {
      background: $color6;
      color: $color4;
    }
  }
}
</style>
