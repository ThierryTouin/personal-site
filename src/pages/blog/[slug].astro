---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="content">
    <h1>{post.data.title}</h1>
    <span class="meta">
      Publié le {new Date(post.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
    </span>
    <Content />
  </article>
</Layout>

<style lang="scss">
@use '../../styles/global.scss' as *;

.content {
  max-width: 750px;
  margin: 0 auto;
  color: $color3;

  h1 {
    font-size: 35px;
    margin: 0 0 10px;
    text-align: center;
  }

  :global(a) {
    color: $color1;
    font-weight: 800;
    &:hover {
      color: #222;
    }
  }

  :global(img) {
    max-width: 100%;
    height: auto;
  }
}

.meta {
  font-size: 13px;
  display: block;
  text-align: center;
  font-weight: 300;
  margin-bottom: 20px;
}
</style>
