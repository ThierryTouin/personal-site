---
import Layout from '../layouts/Layout.astro';
import cv from '../data/cv.json';

const monthNames = ["Janvier", "Février", "Mars", "Avril", "Mai", "Juin",
  "Juillet", "Août", "Septembre", "Octobre", "Novembre", "Décembre"
];

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return "A ce jour";
  const date = new Date(dateStr);
  return `${monthNames[date.getMonth()]} ${date.getFullYear()}`;
}
---

<Layout title="CV" description="Mon CV - Architecte Solution">
  <div class="cv-layout">
    <nav class="cv-menu">
      <ul>
        <li><a href="#info">Info</a></li>
        <li><a href="#experiences">Expériences</a></li>
        <li><a href="#educations">Formations</a></li>
        <li><a href="#knowledges">Compétences</a></li>
        <li><a href="#skills">Skills</a></li>
      </ul>
    </nav>

    <div class="cv-content">
      <!-- Info -->
      <section id="info" class="section">
        <h2>{cv.info.label}</h2>
        <div class="summary" set:html={cv.info.summary} />
      </section>

      <!-- Experiences -->
      <section id="experiences" class="section">
        <h1>Expériences</h1>
        {cv.employment.history.map((job) => (
          <div class="job-item">
            <div class="job-header">
              <div class="job-title">
                <h2>{job.projet}</h2>
                <div class="position">{job.position} - {job.societe} - {job.employer}</div>
              </div>
              <div class="job-date">
                <span>{formatDate(job.start)} - {formatDate(job.end)}</span>
              </div>
            </div>
            <div class="job-body">
              <div set:html={job.summary} />
              <ul>
                {job.highlights.map((h) => (
                  <li set:html={h} />
                ))}
              </ul>
              <ul class="keywords">
                {job.keywords.map((k) => (
                  <li>{k}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </section>

      <!-- Educations -->
      <section id="educations" class="section">
        <h1>Formations</h1>
        {cv.education.history.map((edu) => (
          <div class="edu-item">
            <span class="edu-date">{edu.start}</span>
            <span class="edu-institution"> - {edu.institution}</span>
          </div>
        ))}
      </section>

      <!-- Knowledges -->
      <section id="knowledges" class="section">
        <h1>Compétences</h1>
        {cv.knowledges.sets.map((set) => (
          <div class="skill-set">
            <h2>{set.name}</h2>
            <ul>
              {set.skills.map((s) => (
                <li>{s}</li>
              ))}
            </ul>
          </div>
        ))}
      </section>

      <!-- Skills -->
      <section id="skills" class="section">
        <h1>Skills Techniques</h1>
        {cv.skills.sets.map((set) => (
          <div class="skill-set">
            <h2>{set.name}</h2>
            <ul class="keywords">
              {set.skills.map((s) => (
                <li>{s}</li>
              ))}
            </ul>
          </div>
        ))}
      </section>
    </div>
  </div>
</Layout>

<style lang="scss">
@use '../styles/global.scss' as *;

.cv-layout {
  display: flex;
  width: 100%;
}

.cv-menu {
  width: 20%;

  ul {
    list-style-type: none;
    margin: 0;
    padding: 0;
    width: 200px;
    background-color: $color7;
    position: fixed;
    height: auto;
    overflow: auto;
    cursor: pointer;
    border-radius: 8px;
  }

  li a {
    display: block;
    color: $color6;
    padding: 8px 16px;
    text-decoration: none;
    border-radius: 8px;
    transition: 0.5s all;

    &:hover {
      background-color: $color5;
      color: $color3;
    }
  }
}

.cv-content {
  width: 80%;
}

.section {
  margin-bottom: 2rem;

  h1 {
    color: $color3;
    border-bottom: 1px solid #ddd;
    padding-bottom: 0.5rem;
  }
}

.summary {
  font-style: italic;
  width: 80%;
}

.job-item {
  width: 80%;
  margin-bottom: 1.5rem;

  h2 {
    margin-top: 10px;
    color: $color3;
    font-weight: 1000;
    font-style: italic;
    font-size: large;
    text-align: left;
    text-transform: lowercase;

    &::first-letter {
      text-transform: uppercase;
    }
  }

  .position {
    font-style: italic;
  }
}

.job-header {
  display: grid;
  grid-template-columns: 1fr 300px;
}

.job-date {
  text-align: right;
  padding-top: 20px;
  color: $color6;
}

.job-body {
  .keywords {
    margin-top: 0.5em;

    li {
      display: inline-block;
      white-space: nowrap;
      color: $color6;
      border-style: ridge;
      border-width: 1px;
      border-radius: 10px;
      background: $color7;
      padding-left: 5px;
      padding-right: 5px;
      margin-right: 10px;
      margin-bottom: 10px;

      &:hover {
        background: $color5;
      }
    }
  }
}

.edu-item {
  padding: 5px 0;

  .edu-date {
    color: $color6;
    font-weight: bold;
  }
}

.skill-set {
  width: 80%;

  h2 {
    margin-top: 5px;
    color: $color3;
    font-weight: 1000;
    font-style: italic;
    font-size: large;
    text-align: left;
    text-transform: lowercase;

    &::first-letter {
      text-transform: uppercase;
    }
  }
}

.keywords {
  margin-top: 0.5em;
  list-style: none;
  padding: 0;

  li {
    display: inline-block;
    white-space: nowrap;
    color: $color6;
    border-style: ridge;
    border-width: 1px;
    border-radius: 10px;
    background: $color7;
    padding-left: 5px;
    padding-right: 5px;
    margin-right: 10px;
    margin-bottom: 10px;

    &:hover {
      background: $color5;
    }
  }
}

@media only screen and (max-width: 768px) {
  .cv-layout {
    display: block;
  }

  .cv-menu {
    width: 100%;
    text-align: center;

    ul {
      position: relative;
      width: 100%;
      display: flex;
      flex-flow: wrap;
      justify-content: center;
    }
  }

  .cv-content {
    width: 100%;
  }

  .job-item, .summary, .skill-set {
    width: 100%;
  }

  .job-header {
    grid-template-columns: 1fr;
  }

  .job-date {
    text-align: left;
  }
}
</style>
