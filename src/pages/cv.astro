---
import Layout from '../layouts/Layout.astro';
import CvInfo from '../components/cv/CvInfo.astro';
import CvExperiences from '../components/cv/CvExperiences.astro';
import CvEducation from '../components/cv/CvEducation.astro';
import CvKnowledges from '../components/cv/CvKnowledges.astro';
import CvSkills from '../components/cv/CvSkills.astro';
import PdfExport from '../components/cv/PdfExport.astro';
import cv from '../data/cv.json';

const monthNames = ["Janvier", "Février", "Mars", "Avril", "Mai", "Juin",
  "Juillet", "Août", "Septembre", "Octobre", "Novembre", "Décembre"
];

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return "A ce jour";
  const date = new Date(dateStr);
  return `${monthNames[date.getMonth()]} ${date.getFullYear()}`;
}
---

<Layout title="CV" description="Mon CV - Architecte Solution">
  <div class="cv-layout">
    <nav class="cv-menu">
      <ul>
        <li><a href="#info">Info</a></li>
        <li><a href="#experiences">Expériences</a></li>
        <li><a href="#educations">Formations</a></li>
        <li><a href="#knowledges">Compétences</a></li>
        <li><a href="#skills">Skills</a></li>
      </ul>
    </nav>

    <div class="cv-content">
      <CvInfo label={cv.info.label} summary={cv.info.summary} />
      <CvExperiences history={cv.employment.history} formatDate={formatDate} />
      <CvEducation history={cv.education.history} />
      <CvKnowledges sets={cv.knowledges.sets} />
      <CvSkills sets={cv.skills.sets} />
    </div>
  </div>
</Layout>

<PdfExport />

<style lang="scss">
  @use '../styles/global.scss' as *;

  .cv-layout {
    display: flex;
    width: 100%;
  }

  .cv-menu {
    width: 20%;

    ul {
      list-style-type: none;
      margin: 0;
      padding: 0;
      width: 200px;
      background-color: $color7;
      position: fixed;
      height: auto;
      overflow: auto;
      cursor: pointer;
      border-radius: 8px;
    }

    li a {
      display: block;
      color: $color6;
      padding: 8px 16px;
      text-decoration: none;
      border-radius: 8px;
      transition: 0.5s all;

      &:hover {
        background-color: $color5;
        color: $color3;
      }
    }
  }

  .cv-content {
    width: 80%;
  }

  @media only screen and (max-width: 768px) {
    .cv-layout {
      display: block;
    }

    .cv-menu {
      width: 100%;
      text-align: center;

      ul {
        position: relative;
        width: 100%;
        display: flex;
        flex-flow: wrap;
        justify-content: center;
      }
    }

    .cv-content {
      width: 100%;
    }
  }

  @media print {
    body {
      margin: 0;
      padding: 0;
    }

    .cv-layout {
      display: block;
      width: 100%;
    }

    .cv-menu {
      display: none;
    }

    .cv-content {
      width: 100%;
      padding: 0;
    }

    h1, h2 {
      page-break-after: avoid;
    }

    a {
      color: inherit;
      text-decoration: underline;
    }

    .cv-content > :global(#experiences),
    .cv-content > :global(#educations),
    .cv-content > :global(#knowledges),
    .cv-content > :global(#skills) {
      page-break-before: always;
    }
  }
</style>
