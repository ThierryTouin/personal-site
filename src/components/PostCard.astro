---
interface Props {
  title: string;
  slug: string;
  date: Date;
  description?: string;
  featured?: { src: string };
}

const base = import.meta.env.BASE_URL;
const { title, slug, date, description, featured } = Astro.props;
---

<li class="post">
  {featured && (
    <a href={`${base}blog/${slug}/`} class="featured-link" aria-label={`Lire ${title}`}>
      <img class="featured-image" src={featured.src} alt={`Illustration de ${title}`} loading="lazy" />
    </a>
  )}
  <h2>
    <a href={`${base}blog/${slug}/`}>{title}</a>
  </h2>
  <div class="meta">
    <span>Publié le {new Date(date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
  </div>
  {description && (
    <p class="excerpt">{description}</p>
  )}
  <div class="button">
    <a href={`${base}blog/${slug}/`}>Read More</a>
  </div>
</li>

<style lang="scss">
@use '../styles/global.scss' as *;

.post {
  padding-bottom: 40px;

  &:last-child {
    padding-bottom: 0;
  }

  h2 {
    font-size: 27px;
    margin: 0 0 10px;
    text-align: center;

    a {
      color: $color6;
      &:hover {
        color: #222;
      }
    }
  }
}

.featured-link {
  display: block;
  margin-bottom: 18px;
}

.featured-image {
  width: 100%;
  height: 260px;
  object-fit: cover;
  border-radius: 10px;
  border: 1px solid rgba(0, 0, 0, 0.08);
}

.meta {
  font-size: 13px;
  text-align: center;
  font-weight: 300;
  margin-bottom: 20px;
}

.excerpt {
  margin: 30px 0 15px;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.button {
  font-size: 14px;
  font-weight: 300;
  text-align: center;
  padding: 20px 0;

  a {
    color: #555;
    padding: 8px 12px;
    border: 1px solid #555;
    border-radius: 4px;

    &:hover {
      background: $color6;
      color: $color4;
    }
  }
}
</style>
