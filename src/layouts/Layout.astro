---
interface Props {
  title: string;
  description?: string;
}

import SeoHead from '../components/SeoHead.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/global.scss';
---

<!doctype html>
<html lang="fr">
  <head>
    <SeoHead title={Astro.props.title} description={Astro.props.description} />
  </head>
  <body>
    <div class="container">
      <div class="content">
        <SiteHeader />
        <main class="main-content">
          <slot />
        </main>
      </div>
      <button id="scroll-btn" class="sidebar-btns" style="background-image: url('/arrow-up.svg')" title="Scroll to top"></button>
      <SiteFooter />
    </div>

    <script>
      function initScrollBtn() {
        const btn = document.getElementById('scroll-btn');
        if (!btn) return;
        window.addEventListener('scroll', () => {
          btn.style.display = (document.documentElement.scrollTop > 300) ? 'block' : 'none';
        });
        btn.addEventListener('click', () => {
          document.documentElement.scrollTop = 0;
        });
      }
      initScrollBtn();
      document.addEventListener('astro:after-swap', initScrollBtn);
    </script>
  </body>
</html>

<style>
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.content {
  flex-grow: 1;
}

.main-content {
  margin: 0 auto;
  padding: 3rem 1rem 4rem;
}
</style>
